{
    "name": "phpcorelab/upi-gateway",
    "version": "1.0.0",
    "description": "Provider-agnostic PHP library for UPI QR code generation and payment status polling",
    "type": "library",
    "license": "MIT",
    "keywords": ["upi", "payment", "gateway", "qr", "razorpay", "phonepe", "paytm", "india"],
    "authors": [
        {
            "name": "PHP Core Lab",
            "email": "cscprotech@gmail.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "guzzlehttp/guzzle": "^7.0",
        "psr/log": "^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "mockery/mockery": "^1.6",
        "phpstan/phpstan": "^1.10",
        "squizlabs/php_codesniffer": "^3.7"
    },
    "autoload": {
        "psr-4": {
            "PHPCoreLab\\UpiGateway\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PHPCoreLab\\UpiGateway\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "analyse": "phpstan analyse src --level=8",
        "cs": "phpcs --standard=PSR12 src/"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
